{
  "batch_size": 500,
  "mappings": [
    {
      "name": "users_collection",
      "source": {
        "type": "collection",
        "name": "users"
      },
      "target": {
        "table": "public.users_user",
        "conflict_columns": ["firebase_doc_id"],
        "conflict_action": "update"
      },
      "document_id_column": "firebase_doc_id",
      "document_path_column": "firestore_path",
      "field_map": {
        "uid": "uid",
        "email": "email",
        "phone_number": "phoneNumber",
        "first_name": "profile.firstName",
        "last_name": "profile.lastName",
        "created_at": "createdAt",
        "updated_at": "updatedAt"
      },
      "defaults": {
        "is_active": true
      },
      "raw_json_column": "firestore_raw",
      "required_columns": ["uid"]
    },
    {
      "name": "responses_collection_group",
      "source": {
        "type": "collection_group",
        "name": "responses"
      },
      "target": {
        "table": "public.responses_response",
        "conflict_columns": ["firebase_doc_id"],
        "conflict_action": "update"
      },
      "document_id_column": "firebase_doc_id",
      "parent_document_id_column": "survey_doc_id",
      "field_map": {
        "user_uid": "uid",
        "answer": "answer",
        "submitted_at": "submittedAt"
      },
      "raw_json_column": "firestore_raw"
    }
  ]
}
